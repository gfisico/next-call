# SQLite データベースファイルのパス（開発: ./data/next-call.db、本番: /data/next-call.db）
DATABASE_PATH=./data/next-call.db

# Auth.js v5（`npx auth secret` で生成）
AUTH_SECRET=

# Google OAuth クライアント（Google Cloud Console で発行）
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ログインを許可するメールアドレス（カンマ区切り。未設定は全拒否）
ALLOWED_EMAILS=

# タイムゾーン（日付の解釈は JST が正。固定）
TZ=Asia/Tokyo
