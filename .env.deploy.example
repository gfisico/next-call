# next-call 本番デプロイ用 環境変数テンプレート。
# VPS 上で `.env` にコピーして実値を設定する（cp .env.deploy.example .env）。
# .env は絶対にコミットしない（.dockerignore / .gitignore で除外済み）。

# --- データベース -----------------------------------------------------------
# コンテナ内の SQLite パス。compose の volume /srv/next-call/data:/data と対応。
# 通常この値は変更不要。
DATABASE_PATH=/data/next-call.db

# --- 認証（Auth.js v5） ------------------------------------------------------
# `openssl rand -base64 32` もしくは `npx auth secret` で生成した値。
AUTH_SECRET=

# Google Cloud Console で発行した OAuth クライアント。
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ログインを許可するメールアドレス（カンマ区切り。未設定は全拒否）。
ALLOWED_EMAILS=

# アプリの公開 URL（https://<APP_DOMAIN>）。OAuth コールバックの基点。
# Google OAuth のリダイレクト URI は <AUTH_URL>/api/auth/callback/google を登録する。
AUTH_URL=https://example.com

# --- タイムゾーン ------------------------------------------------------------
# 日付解釈は JST が正（固定）。
TZ=Asia/Tokyo

# --- 公開ドメイン ------------------------------------------------------------
# 公開ドメイン（DNS の A レコードを VPS の IP に向けておく）。
# nginx 統合方式では nginx / certbot がこのドメインを扱う（Caddy は不使用）。
APP_DOMAIN=example.com
# Let's Encrypt 証明書発行時の連絡先メールアドレス（certbot に渡す）。
ACME_EMAIL=admin@example.com

# --- イメージ（ロールバック時のみ指定） --------------------------------------
# 通常は未設定（compose の既定 latest を使用）。
# ロールバック時は特定 SHA を指定: APP_IMAGE=ghcr.io/gfisico/next-call:<sha>
# APP_IMAGE=ghcr.io/gfisico/next-call:latest
